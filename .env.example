# Geotab Direct API
GEOTAB_DATABASE=your_geotab_database
GEOTAB_USERNAME=your_geotab_username
GEOTAB_PASSWORD=your_geotab_password
GEOTAB_SERVER=my.geotab.com

# Maps / Geocoding
# Server-side key: used for Geocoding API, Places API, Static Maps (PDF export).
# Apply IP address restrictions in Google Cloud Console.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Client-side key: used for the interactive Google Street View panorama in the
# dashboard. Enable "Maps JavaScript API" in Google Cloud Console and apply
# HTTP referrer restrictions (e.g. https://yourdomain.com/*).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

MAPBOX_ACCESS_TOKEN=

# ─── Google Cloud (Vertex AI Gemini + BigQuery + Cloud Run + TTS) ─────────────
# Primary LLM provider. When GOOGLE_CLOUD_PROJECT is set, Vertex AI Gemini is
# used as the first-choice LLM (gemini-1.5-pro for stories, gemini-2.0-flash for
# briefings). Falls back to ANTHROPIC_API_KEY → OPENAI_API_KEY if not set.
#
# Also powers the /api/tts route (Google Cloud Text-to-Speech, Journey-D voice).
# Enable "Cloud Text-to-Speech API" in Google Cloud Console for your project.
#
# Local dev:  gcloud auth application-default login
# Cloud Run:  attach a service account with roles/aiplatform.user + roles/cloudtextospeech.admin
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# BigQuery dataset for analytics cache (created automatically on first write)
BIGQUERY_DATASET=fleethappens

# ─── Fallback LLM providers ───────────────────────────────────────────────────
# Only used when GOOGLE_CLOUD_PROJECT is not set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Session encryption — used to encrypt Geotab session cookies for per-user auth.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_64_char_hex_string_here

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3002

# LLM kill-switch — set to "false" to disable all AI calls across digest, next-stop, and story.
# When disabled, each feature falls back to its deterministic/demo path automatically.
LLM_ENABLED=true

# Demo mode — set to "true" to force the Pulse pages to use fallback JSON data
# (pulse-summary.json + pulse-fleet-*.json) instead of live Geotab API calls.
# Useful for demos where the Geotab account has no custom regional sub-groups.
# Set to "false" (or remove) to use live data.
PULSE_DEMO_GROUPS=false

# Demo mode — set to "true" to populate the Fleet Storybook with bundled demo
# stories (public/fallback/storybook.json) instead of querying BigQuery.
STORYBOOK_DEMO_DATA=false

# ─── Enterprise integrations (optional) ────────────────────────────────────────
# Slack Incoming Webhook URL — used for message-only sharing (no PDF upload)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Slack Bot Token + Channel — required for PDF file upload to Slack
# Bot needs scopes: files:write, chat:write
# Create a Slack app at: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Microsoft Teams Incoming Webhook URL — omit to run in mock/demo mode
# When set, PDFs are generated server-side and a 1-hour download link is included in the card.
# Create one at: https://learn.microsoft.com/en-us/microsoftteams/platform/webhooks-and-connectors/how-to/add-incoming-webhook
TEAMS_WEBHOOK_URL=
